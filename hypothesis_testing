def fix_mixed_encoding(text):
    if pd.isna(text):
        return 'Unknown'

    text = str(text)

    # Заменяем кириллические символы, которые выглядят как латинские
    replacements = {
        'а': 'a', 'с': 'c', 'е': 'e', 'о': 'o', 'р': 'p',
        'у': 'y', 'х': 'x', 'к': 'k', 'А': 'A', 'С': 'C',
        'Е': 'E', 'О': 'O', 'Р': 'P', 'У': 'Y', 'Х': 'X',
        'К': 'K', 'М': 'M', 'Т': 'T', 'Н': 'H', 'В': 'B'
    }

    for wrong, correct in replacements.items():
        text = text.replace(wrong, correct)

    return text.strip()


