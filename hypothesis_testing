# 1 гипотеза. Влияет ли тип устройства на количество покупок в день по каждому региону?
print('1 гипотеза. Влияет ли тип устройства на количество покупок в день по каждому региону?')
daily_purchases = df.groupby(['session_date', 'region', 'device'])['payer'].sum().reset_index()
daily_purchases = daily_purchases.rename(columns={'payer': 'purchases_per_day'})


# Проверяем, есть ли данные
if len(daily_purchases) == 0:
    print("Нет данных для анализа!")
else:
    def test_device_effect_simple(region_data):
        """Упрощенная проверка влияния устройства"""
        devices = region_data['device'].unique()
        if len(devices) < 2:
            return None, "Недостаточно устройств"

        # Сразу используем непараметрические тесты (они более устойчивы)
        if len(devices) == 2:
            # Два устройства - Манна-Уитни
            device1, device2 = devices
            data1 = region_data[region_data['device'] == device1]['purchases_per_day']
            data2 = region_data[region_data['device'] == device2]['purchases_per_day']

            # Проверяем, достаточно ли данных
            if len(data1) < 3 or len(data2) < 3:
                return None, "Недостаточно данных"

            try:
                u_stat, p_value = mannwhitneyu(data1, data2, alternative='two-sided')
                test = "Манна-Уитни"
                return p_value, test
            except:
                return None, "Ошибка в тесте"
        else:
            # Более двух устройств - Крускал-Уоллис
            groups = []
            for device in devices:
                data = region_data[region_data['device'] == device]['purchases_per_day']
                if len(data) >= 1:
                    groups.append(data)

            if len(groups) < 2:
                return None, "Недостаточно групп"

            try:
                h_stat, p_value = kruskal(*groups)
                test = "Крускал-Уоллис"
                return p_value, test
            except:
                return None, "Ошибка в тесте"


    # Проверяем по регионам
    results = []
    for region in daily_purchases['region'].unique():
        region_data = daily_purchases[daily_purchases['region'] == region]
        p_value, test = test_device_effect_simple(region_data)

        if p_value is not None:
            significant = p_value < 0.05
            conclusion = "Влияет" if significant else "Не влияет"
        else:
            conclusion = "Недостаточно данных"
            test = "N/A"

        results.append({
            'Регион': region,
            'Тест': test,
            'p-value': f"{p_value:.4f}" if p_value is not None else "N/A",
            'Вывод': conclusion
        })

    results_df = pd.DataFrame(results)
    print("\nРезультаты проверки гипотезы 1:")
    print(results_df.to_string(index=False))

